<script>
  // Nav scroll state
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 40));

  // Smooth scroll for ALL anchor links (nav + hero buttons)
  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', e => {
      const target = document.querySelector(link.getAttribute('href'));
      if (target) {
        e.preventDefault();
        const offset = target.getBoundingClientRect().top + window.scrollY - 70;
        window.scrollTo({ top: offset, behavior: 'smooth' });
      }
    });
  });

  // Case accordions
  document.querySelectorAll('.case').forEach(c => {
    c.querySelector('.chd').addEventListener('click', () => {
      document.querySelectorAll('.case.open').forEach(o => { if(o!==c) o.classList.remove('open'); });
      c.classList.toggle('open');
    });
  });

  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('vis'); obs.unobserve(e.target); }});
  }, { threshold: 0.07, rootMargin: '0px 0px -30px 0px' });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  // Experience nav
  document.querySelectorAll('.enl').forEach(l => {
    l.addEventListener('click', e => {
      e.preventDefault();
      document.querySelectorAll('.enl').forEach(x => x.classList.remove('active'));
      l.classList.add('active');
      const t = document.querySelector(l.getAttribute('href'));
      if(t) t.scrollIntoView({behavior:'smooth', block:'start'});
    });
  });

  // Active nav highlight on scroll
  const secs = ['about','work','experience','skills','locations','contact'];
  window.addEventListener('scroll', () => {
    let cur = '';
    secs.forEach(id => { const el = document.getElementById(id); if(el && scrollY >= el.offsetTop - 120) cur = id; });
    document.querySelectorAll('.nlinks a').forEach(a => {
      a.classList.toggle('active', a.getAttribute('href') === `#${cur}`);
    });
  });
</script>
