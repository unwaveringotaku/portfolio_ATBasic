<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Abhishek Tewari — Product Strategy & AI Systems</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:#050810; --bg2:#080d1a; --bgc:#0b1120; --bgc2:#0e1628;
      --cyan:#00f5ff; --cdim:rgba(0,245,255,0.12); --cglow:rgba(0,245,255,0.32);
      --mag:#ff2d78; --mdim:rgba(255,45,120,0.12);
      --green:#00ff88;
      --tx:#c8d8f0; --txd:#6a7fa0; --txm:#3a4a60;
      --bdr:rgba(0,245,255,0.1); --bdrh:rgba(0,245,255,0.38);
      --mono:'Share Tech Mono',monospace;
      --title:'Orbitron',sans-serif;
      --body:'Inter',sans-serif;
      --max:1100px; --ease:0.3s cubic-bezier(0.25,0.46,0.45,0.94);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{background:var(--bg);color:var(--tx);font-family:var(--body);font-weight:300;line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
    a{color:inherit;text-decoration:none;}
    /* scanlines */
    body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.025) 2px,rgba(0,0,0,0.025) 4px);pointer-events:none;z-index:9999;}
    /* scrollbar */
    ::-webkit-scrollbar{width:3px;} ::-webkit-scrollbar-track{background:var(--bg);} ::-webkit-scrollbar-thumb{background:var(--cyan);}
    /* layout */
    .wrap{max-width:var(--max);margin:0 auto;padding:0 2rem;}
    .section{padding:7rem 0;}
    /* ── EDUCATION STRIP ── */
    .edu-strip{background:var(--bg2);border-top:1px solid var(--bdr);border-bottom:1px solid var(--bdr);padding:2rem 0;position:relative;z-index:1;}
    .edu-inner{display:flex;flex-direction:column;gap:0;}
    .edu-item{display:flex;align-items:center;gap:1.5rem;padding:1rem 0;flex-wrap:wrap;}
    .edu-item:first-child{border-bottom:1px solid var(--bdr);}
    .edu-badge{font-family:var(--title);font-size:.72rem;font-weight:700;color:var(--bg);background:var(--cyan);padding:.3rem .6rem;border-radius:2px;letter-spacing:.08em;flex-shrink:0;min-width:38px;text-align:center;}
    .edu-info{flex:1;min-width:0;}
    .edu-school{font-family:var(--title);font-size:.78rem;font-weight:600;color:#fff;letter-spacing:.03em;margin-bottom:.2rem;}
    .edu-degree{font-family:var(--mono);font-size:.65rem;color:var(--txd);letter-spacing:.05em;}
    .edu-meta{text-align:right;flex-shrink:0;}
    .edu-gpa{font-family:var(--title);font-size:.9rem;font-weight:700;color:var(--cyan);text-shadow:0 0 12px var(--cglow);}
    .edu-year{font-family:var(--mono);font-size:.62rem;color:var(--txm);letter-spacing:.08em;margin-top:.15rem;}
    .edu-avail{display:flex;align-items:center;gap:.5rem;font-family:var(--mono);font-size:.65rem;color:var(--green);letter-spacing:.06em;border:1px solid rgba(0,255,136,.2);padding:.3rem .75rem;border-radius:2px;background:rgba(0,255,136,.03);flex-shrink:0;white-space:nowrap;}
    .edu-dot{width:6px;height:6px;background:var(--green);border-radius:50%;box-shadow:0 0 8px rgba(0,255,136,.8);animation:blink 1.8s infinite;flex-shrink:0;}

    hr.rule{border:none;border-top:1px solid var(--bdr);}
    /* type helpers */
    .lbl{font-family:var(--mono);font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--cyan);}
    /* grid bg */
    .gridbg{position:fixed;inset:0;background:linear-gradient(rgba(0,245,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,245,255,0.025) 1px,transparent 1px);background-size:55px 55px;pointer-events:none;z-index:0;}
    .gridbg::before{content:'';position:absolute;top:-20%;right:-10%;width:60%;height:70%;background:radial-gradient(ellipse,rgba(0,245,255,0.055) 0%,transparent 65%);}
    .gridbg::after{content:'';position:absolute;bottom:-10%;left:-10%;width:50%;height:50%;background:radial-gradient(ellipse,rgba(255,45,120,0.04) 0%,transparent 65%);}

    /* ── NAV ─────────────────────────────────────────────────── */
    nav{position:fixed;top:0;left:0;right:0;z-index:200;height:62px;display:flex;align-items:center;justify-content:space-between;padding:0 2.5rem;background:rgba(5,8,16,0.88);backdrop-filter:blur(20px);border-bottom:1px solid var(--bdr);transition:border-color var(--ease);}
    nav::before{content:'';position:absolute;bottom:-1px;left:0;width:80px;height:2px;background:linear-gradient(90deg,var(--cyan),transparent);}
    nav::after{content:'';position:absolute;bottom:-1px;right:0;width:80px;height:2px;background:linear-gradient(270deg,var(--mag),transparent);}
    nav.scrolled{border-bottom-color:var(--bdrh);}
    .nlogo{font-family:var(--title);font-size:0.9rem;font-weight:700;letter-spacing:0.12em;color:var(--tx);}
    .nlogo span{color:var(--cyan);}
    /* always-visible nav links */
    .nlinks{display:flex;align-items:center;gap:0.2rem;list-style:none;}
    .nlinks a{font-family:var(--mono);font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--txd);padding:0.38rem 0.8rem;border:1px solid transparent;border-radius:2px;transition:color var(--ease),border-color var(--ease),background var(--ease);}
    .nlinks a:hover,.nlinks a.active{color:var(--cyan);border-color:var(--bdrh);background:var(--cdim);}
    .ncta{font-family:var(--mono);font-size:0.66rem;letter-spacing:0.12em;text-transform:uppercase;padding:0.42rem 1.1rem;border:1px solid var(--cyan);border-radius:2px;color:var(--cyan);transition:background var(--ease),color var(--ease),box-shadow var(--ease);white-space:nowrap;}
    .ncta:hover{background:var(--cyan);color:var(--bg);box-shadow:0 0 22px var(--cglow);}

    /* ── HERO ────────────────────────────────────────────────── */
    .hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:100px 2rem 4rem;max-width:var(--max);margin:0 auto;position:relative;z-index:1;}
    .hero-eye{display:flex;align-items:center;gap:1rem;margin-bottom:2rem;opacity:0;animation:up 0.7s ease forwards 0.3s;}
    .heyline{width:30px;height:1px;background:var(--cyan);box-shadow:0 0 8px var(--cyan);}
    .hero-title{font-family:var(--title);font-size:clamp(2rem,5vw,4rem);font-weight:900;line-height:1.1;letter-spacing:0.01em;color:#fff;opacity:0;animation:up 0.7s ease forwards 0.5s;}
    .hero-title .c{color:var(--cyan);text-shadow:0 0 28px var(--cglow);}
    .hero-title .m{color:var(--mag);text-shadow:0 0 28px rgba(255,45,120,0.4);}
    /* glitch on first line */
    .glitch{position:relative;}
    .glitch::before,.glitch::after{content:attr(data-text);position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;}
    .glitch::before{color:var(--cyan);clip-path:polygon(0 0,100% 0,100% 45%,0 45%);transform:translateX(-2px);opacity:0;animation:g1 5s infinite 3s;}
    .glitch::after{color:var(--mag);clip-path:polygon(0 55%,100% 55%,100% 100%,0 100%);transform:translateX(2px);opacity:0;animation:g2 5s infinite 3.1s;}
    @keyframes g1{0%,93%,100%{opacity:0;}94%{opacity:.7;transform:translateX(-4px);}96%{opacity:.7;transform:translateX(2px);}}
    @keyframes g2{0%,93%,100%{opacity:0;}94%{opacity:.7;transform:translateX(4px);}96%{opacity:.7;transform:translateX(-2px);}}
    .hero-sub{max-width:570px;font-size:1rem;color:var(--txd);line-height:1.85;margin:1.75rem 0 2.5rem;opacity:0;animation:up 0.7s ease forwards 0.7s;}
    .hero-btns{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:up 0.7s ease forwards 0.9s;margin-bottom:4rem;}
    .bcyan{font-family:var(--mono);font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;padding:.85rem 2rem;background:var(--cyan);color:var(--bg);border-radius:2px;display:inline-block;transition:box-shadow var(--ease),transform var(--ease);}
    .bcyan:hover{box-shadow:0 0 28px var(--cglow),0 0 60px rgba(0,245,255,0.12);transform:translateY(-2px);}
    .boutline{font-family:var(--mono);font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;padding:.85rem 2rem;background:transparent;border:1px solid var(--bdrh);color:var(--cyan);border-radius:2px;display:inline-block;transition:background var(--ease),box-shadow var(--ease),transform var(--ease);}
    .boutline:hover{background:var(--cdim);box-shadow:0 0 20px var(--cglow);transform:translateY(-2px);}
    .hstats{display:flex;gap:3rem;flex-wrap:wrap;border-top:1px solid var(--bdr);padding-top:2rem;opacity:0;animation:up 0.7s ease forwards 1.1s;}
    .snum{font-family:var(--title);font-size:1.6rem;font-weight:700;color:var(--cyan);line-height:1;margin-bottom:.3rem;text-shadow:0 0 18px var(--cglow);}
    .slbl{font-family:var(--mono);font-size:0.62rem;letter-spacing:.1em;color:var(--txm);text-transform:uppercase;}

    /* ── STRIP ───────────────────────────────────────────────── */
    .strip{border-top:1px solid var(--bdr);border-bottom:1px solid var(--bdr);padding:3rem 0;background:var(--bg2);position:relative;z-index:1;}
    .strip::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--cyan),transparent);}
    .strip-inner{display:grid;grid-template-columns:repeat(3,1fr);}
    .si{padding:1.5rem 2rem;border-right:1px solid var(--bdr);position:relative;}
    .si:last-child{border-right:none;}
    .si::before{content:'';position:absolute;top:0;left:0;width:2px;height:0;background:var(--cyan);transition:height .5s ease;}
    .si:hover::before{height:100%;}
    .sin{font-family:var(--mono);font-size:0.63rem;color:var(--cyan);letter-spacing:.12em;margin-bottom:.75rem;}
    .sit{font-family:var(--title);font-size:0.8rem;font-weight:600;color:#fff;letter-spacing:.05em;margin-bottom:.45rem;}
    .sib{font-size:0.84rem;color:var(--txd);line-height:1.65;}

    /* ── SECTION HEADING ─────────────────────────────────────── */
    .sec-h{font-family:var(--title);font-size:clamp(1.5rem,2.8vw,2.2rem);font-weight:700;color:#fff;letter-spacing:.02em;line-height:1.2;margin-top:.7rem;}
    .sec-h span{color:var(--cyan);}

    /* ── ABOUT ───────────────────────────────────────────────── */
    .about-grid{display:grid;grid-template-columns:1fr 1.5fr;gap:5rem;align-items:start;}
    .about-left{position:sticky;top:80px;}
    .about-body p{font-size:.94rem;color:var(--txd);margin-bottom:1.2rem;line-height:1.85;}
    .about-body p strong{color:var(--tx);font-weight:500;}
    .tags{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:1.5rem;}
    .tag{font-family:var(--mono);font-size:.63rem;letter-spacing:.07em;padding:.28rem .7rem;border:1px solid var(--bdr);border-radius:2px;color:var(--txd);background:var(--bgc);transition:border-color var(--ease),color var(--ease),background var(--ease);}
    .tag:hover{border-color:var(--cyan);color:var(--cyan);background:var(--cdim);}

    /* ── CASES ───────────────────────────────────────────────── */
    .whd{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.5rem;flex-wrap:wrap;gap:1rem;}
    .cases{display:flex;flex-direction:column;gap:1rem;}
    .case{border:1px solid var(--bdr);background:var(--bgc);border-radius:4px;overflow:hidden;transition:border-color var(--ease),box-shadow var(--ease),transform var(--ease);position:relative;}
    .case::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:linear-gradient(180deg,var(--cyan),var(--mag));opacity:0;transition:opacity var(--ease);}
    .case:hover,.case.open{border-color:var(--bdrh);box-shadow:0 0 28px rgba(0,245,255,0.05);}
    .case.open::before,.case:hover::before{opacity:1;}
    .chd{display:grid;grid-template-columns:2.5rem 1fr auto;align-items:center;gap:1rem;padding:1.4rem 1.75rem;cursor:pointer;border-bottom:1px solid transparent;transition:border-color var(--ease);}
    .case.open .chd{border-bottom-color:var(--bdr);}
    .cn{font-family:var(--mono);font-size:.63rem;color:var(--txm);letter-spacing:.1em;}
    .ct{font-size:.96rem;font-weight:500;color:var(--tx);margin-bottom:.35rem;}
    .chips{display:flex;flex-wrap:wrap;gap:.3rem;}
    .chip{font-family:var(--mono);font-size:.58rem;letter-spacing:.06em;text-transform:uppercase;padding:.18rem .55rem;background:rgba(0,245,255,0.05);border:1px solid var(--bdr);border-radius:2px;color:var(--txd);}
    .tog{width:28px;height:28px;border:1px solid var(--bdr);border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:1rem;color:var(--txd);transition:all var(--ease);flex-shrink:0;user-select:none;font-family:var(--mono);}
    .case.open .tog{background:var(--cyan);color:var(--bg);border-color:var(--cyan);box-shadow:0 0 14px var(--cglow);transform:rotate(45deg);}
    .cbody{display:none;padding:2rem 1.75rem;}
    .case.open .cbody{display:block;}
    .cgrid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;}
    .cbl{font-family:var(--mono);font-size:.58rem;letter-spacing:.14em;text-transform:uppercase;color:var(--cyan);margin-bottom:.45rem;}
    .cbt{font-size:.88rem;color:var(--txd);line-height:1.75;}
    .ibox{background:rgba(0,245,255,0.03);border:1px solid rgba(0,245,255,0.14);border-left:3px solid var(--cyan);padding:1rem 1.5rem;border-radius:0 4px 4px 0;margin-bottom:1.25rem;}
    .ibox ul{list-style:none;}
    .ibox li{font-size:.88rem;color:var(--tx);padding:.22rem 0;}
    .ibox li::before{content:'→ ';color:var(--cyan);}
    .qbox{padding:1rem 1.5rem;border:1px dashed rgba(0,245,255,0.16);border-radius:4px;background:rgba(0,245,255,0.02);}
    .qbox p{font-size:.88rem;color:var(--txd);font-style:italic;line-height:1.7;}

    /* ── EXPERIENCE ──────────────────────────────────────────── */
    .expwrap{display:block;}
    .expnav{position:sticky;top:80px;height:fit-content;min-width:0;}
    .enl{display:block;font-family:var(--mono);font-size:.62rem;letter-spacing:.06em;text-transform:uppercase;padding:.5rem 0 .5rem .85rem;border-left:2px solid var(--bdr);color:var(--txm);cursor:pointer;transition:all var(--ease);margin-bottom:.1rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .enl:hover,.enl.active{border-left-color:var(--cyan);color:var(--cyan);padding-left:1.1rem;}
    .tl{display:flex;flex-direction:column;}
    .ti{padding:1.75rem 0;border-bottom:1px solid var(--bdr);}
    .ti:last-child{border-bottom:none;}
    .titop{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:.75rem;}
    .tirole{font-family:var(--title);font-size:.82rem;font-weight:600;color:#fff;letter-spacing:.03em;margin-bottom:.2rem;}
    .tico{font-family:var(--mono);font-size:.7rem;color:var(--cyan);letter-spacing:.06em;}
    .tidt{font-family:var(--mono);font-size:.63rem;color:var(--txm);white-space:nowrap;padding-top:.15rem;letter-spacing:.05em;}
    .til{list-style:none;display:flex;flex-direction:column;gap:.35rem;}
    .til li{font-size:.86rem;color:var(--txd);line-height:1.65;padding-left:1.1rem;position:relative;}
    .til li::before{content:'//';position:absolute;left:0;color:var(--cyan);font-family:var(--mono);font-size:.6rem;top:.22rem;}

    /* ── SKILLS ──────────────────────────────────────────────── */
    .skgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;}
    .sk{background:var(--bgc);border:1px solid var(--bdr);border-radius:4px;padding:1.5rem;position:relative;overflow:hidden;transition:border-color var(--ease),box-shadow var(--ease),transform var(--ease);}
    .sk::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--cyan),var(--mag));transform:scaleX(0);transform-origin:left;transition:transform .4s ease;}
    .sk:hover{border-color:var(--bdrh);box-shadow:0 0 22px rgba(0,245,255,0.06);transform:translateY(-2px);}
    .sk:hover::after{transform:scaleX(1);}
    .ski{font-size:1.2rem;margin-bottom:.75rem;}
    .skt{font-family:var(--title);font-size:.76rem;font-weight:600;color:#fff;letter-spacing:.05em;margin-bottom:.7rem;}
    .skl{list-style:none;display:flex;flex-direction:column;gap:.3rem;}
    .skl li{font-size:.81rem;color:var(--txd);padding-left:.75rem;position:relative;line-height:1.5;}
    .skl li::before{content:'>';position:absolute;left:0;color:var(--cyan);font-family:var(--mono);font-size:.68rem;}

    /* ── LOCATIONS ───────────────────────────────────────────── */
    .locsec{background:var(--bg2);border-top:1px solid var(--bdr);border-bottom:1px solid var(--bdr);padding:5rem 0;position:relative;overflow:hidden;z-index:1;}
    .locsec::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--mag),transparent);}
    .locgrid{display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;margin-top:2.5rem;}
    .lcard{background:var(--bgc);border:1px solid var(--bdr);border-radius:4px;padding:1.5rem;text-align:center;position:relative;overflow:hidden;transition:border-color var(--ease),box-shadow var(--ease),transform var(--ease);}
    .lcard::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(0,245,255,0.04) 0%,transparent 60%);opacity:0;transition:opacity var(--ease);}
    .lcard:hover{border-color:var(--cyan);box-shadow:0 0 28px rgba(0,245,255,0.1);transform:translateY(-3px);}
    .lcard:hover::before{opacity:1;}
    .lcard.cur{border-color:rgba(0,245,255,0.28);}
    .lcard.cur::after{content:'CURRENT';position:absolute;top:.6rem;right:.75rem;font-family:var(--mono);font-size:.52rem;letter-spacing:.1em;color:var(--green);border:1px solid rgba(0,255,136,0.28);padding:.13rem .38rem;border-radius:2px;}
    .lflag{font-size:2rem;margin-bottom:.75rem;display:block;}
    .lcity{font-family:var(--title);font-size:.82rem;font-weight:700;color:#fff;letter-spacing:.08em;margin-bottom:.22rem;}
    .lcountry{font-family:var(--mono);font-size:.62rem;color:var(--txm);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.75rem;}
    .lstatus{font-family:var(--mono);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;}
    .lstatus.open{color:var(--green);}
    .lstatus.cur{color:var(--cyan);}
    .reloc{margin-top:1.75rem;padding:1rem 1.5rem;border:1px solid var(--bdr);background:var(--bgc);border-radius:4px;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;}
    .rdot{width:8px;height:8px;background:var(--green);border-radius:50%;flex-shrink:0;box-shadow:0 0 10px rgba(0,255,136,.6);animation:blink 1.8s infinite;}
    @keyframes blink{0%,100%{opacity:1;}50%{opacity:.3;}}
    .rtxt{font-family:var(--mono);font-size:.7rem;color:var(--txd);letter-spacing:.05em;}
    .rtxt strong{color:var(--tx);}

    /* ── CONTACT ─────────────────────────────────────────────── */
    .ctcsec{background:var(--bg);padding:7rem 0;position:relative;z-index:1;}
    .ctcsec::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--cyan),transparent);}
    .ctcgrid{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;}
    .ctch{font-family:var(--title);font-size:clamp(1.4rem,2.4vw,2rem);font-weight:700;color:#fff;letter-spacing:.03em;line-height:1.3;margin:.75rem 0 1.25rem;}
    .ctch span{color:var(--cyan);text-shadow:0 0 18px var(--cglow);}
    .ctcsub{font-size:.92rem;color:var(--txd);line-height:1.85;margin-bottom:1.75rem;max-width:400px;}
    .avail{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--mono);font-size:.66rem;letter-spacing:.08em;color:var(--green);border:1px solid rgba(0,255,136,.22);padding:.5rem 1rem;border-radius:2px;background:rgba(0,255,136,.03);}
    .dot{width:7px;height:7px;background:var(--green);border-radius:50%;box-shadow:0 0 8px rgba(0,255,136,.8);animation:blink 1.8s infinite;}
    .ctclinks{display:flex;flex-direction:column;}
    .cl{display:flex;align-items:center;gap:1rem;font-size:.875rem;color:var(--txd);padding:1rem 0;border-bottom:1px solid var(--bdr);transition:color var(--ease),padding-left var(--ease);}
    .cl:last-child{border-bottom:none;}
    .cl:hover{color:var(--cyan);padding-left:.5rem;}
    .cll{font-family:var(--mono);font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--txm);min-width:64px;}
    .cla{margin-left:auto;opacity:0;transition:opacity var(--ease),transform var(--ease);font-family:var(--mono);}
    .cl:hover .cla{opacity:1;transform:translateX(4px);}

